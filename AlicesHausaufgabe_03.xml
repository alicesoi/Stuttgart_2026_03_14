	"oa:hasBody": {
		"@type": "cwrc:Note",
		"dc:format": "text/plain",
		"rdf:value": "Hoffmann datiert das Jahr seiner Erzählung nicht konkret, vermutlich soll es sich aber um die Wende vom 18. zum 19. Jahrhundert handeln, weil die meisten seiner Erzählungen in der Zeit der frühen Romantik spielen. "
